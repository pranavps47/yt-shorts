# Copy this file to `.env` and fill in what you use.
# `.env` is gitignored — never commit real keys.

# REQUIRED — Google Gemini API key, used for Veo 3 video generation.
# Needs Veo access + billing enabled. https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OPTIONAL — Claude, used only for prompt splitting. Two ways to authenticate:
#   1) OAuth (keyless, recommended): run `ant auth login` once, leave this unset.
#      Install the Anthropic CLI first: brew install anthropics/tap/ant
#   2) API key: uncomment and paste a key from https://console.anthropic.com/settings/keys
# A blank value is ignored so it won't shadow an OAuth login.
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OPTIONAL — fal.ai key for the alternative video backend (VIDEO_BACKEND=fal).
# $10 free credits on signup. https://fal.ai (Dashboard > Keys).
# FAL_KEY=your-fal-key-here
# VIDEO_BACKEND=fal          # uncomment to generate clips with fal instead of Veo
